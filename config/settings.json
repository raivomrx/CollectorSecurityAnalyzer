{
  "app": {
    "name": "Collector Security Analyzer",
    "log_level": "INFO"
  },
  "parser": {
    "encodings": ["utf-8-sig", "utf-8", "cp1252"]
  },
  "risk": {
    "default_category": "general"
  },
  "CVE": {
    "Enabled": true,
    "Provider": "NVD",
    "ApiKeyEnvironmentVariable": "NVD_API_KEY",
    "RequestTimeoutSeconds": 30,
    "MaxRetries": 3,
    "CacheTtlHours": 24,
    "MinimumCpeConfidence": 80,
    "AmbiguousScoreDifference": 5,
    "IncludePossibleMatches": true,
    "IncludeNotEvaluated": true,
    "RateLimitWithoutApiKey": {
      "Requests": 5,
      "WindowSeconds": 30
    },
    "RateLimitWithApiKey": {
      "Requests": 50,
      "WindowSeconds": 30
    }
  },
  "VulnerabilityEnrichment": {
    "Enabled": true,
    "CisaKev": {
      "Enabled": true,
      "FeedUrl": "https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json",
      "CacheTtlHours": 6,
      "AllowStaleCache": true
    },
    "CveProgram": {
      "Enabled": true,
      "Mode": "REMOTE_RECORD",
      "LocalRepositoryPath": "",
      "RawBaseUrl": "https://raw.githubusercontent.com/CVEProject/cvelistV5/main/cves",
      "CacheTtlHours": 24,
      "AllowStaleCache": true
    },
    "EnrichNotAffected": false
  },
  "Prioritization": {
    "KevWeight": 50,
    "RansomwareWeight": 15,
    "AffectedWeight": 20,
    "PossibleWeight": 10,
    "CriticalCvssWeight": 15,
    "HighCvssWeight": 10,
    "MediumCvssWeight": 5,
    "CnaConfirmationWeight": 10,
    "ConflictPenalty": 20
  }
}
