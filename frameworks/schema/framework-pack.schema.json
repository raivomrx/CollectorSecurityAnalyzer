{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csa.local/schema/framework-pack.schema.json",
  "title": "CSA Versioned Framework Content Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "frameworkId", "name", "version", "status", "assessmentMode", "source", "scope", "license", "createdAt", "updatedAt", "maintainer", "minimumCsaVersion", "deprecated", "controls", "contentHashSha256"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "frameworkId": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "REVIEW_REQUIRED", "DRAFT", "DEPRECATED", "ARCHIVED"]},
    "assessmentMode": {"enum": ["FORMAL_ASSESSMENT", "TRACEABILITY_ONLY"]},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publisher", "release", "publishedAt", "retrievedAt", "reference"],
      "properties": {
        "publisher": {"type": "string", "minLength": 1},
        "release": {"type": ["string", "null"]},
        "publishedAt": {"type": ["string", "null"], "format": "date"},
        "retrievedAt": {"type": "string", "format": "date"},
        "reference": {"type": "string", "minLength": 1},
        "digestSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
        ,"sourceDigestSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
        ,"sourceFileName": {"type": ["string", "null"], "maxLength": 512}
        ,"sourceFormat": {"type": ["string", "null"], "enum": ["CSV", "JSON", null]}
        ,"importedAt": {"type": ["string", "null"], "format": "date-time"}
        ,"recordCount": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "license": {"type": "string", "minLength": 1},
    "disclaimers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "en": {"type": "string", "minLength": 1},
        "et": {"type": "string", "minLength": 1}
      }
    },
    "createdAt": {"type": "string", "format": "date"},
    "updatedAt": {"type": "string", "format": "date"},
    "maintainer": {"type": "string", "minLength": 1},
    "minimumCsaVersion": {"type": "string", "minLength": 1},
    "deprecated": {"type": "boolean"},
    "supersedes": {"type": ["string", "null"]},
    "supersededBy": {"type": ["string", "null"]},
    "controls": {"type": "array", "items": {"$ref": "framework-control.schema.json"}},
    "contentHashSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
