{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "collector-schema-2.0.json",
  "title": "Collector Security Analyzer Collector Schema 2.0",
  "type": "object",
  "required": [
    "schemaVersion",
    "collectorVersion",
    "collectionId",
    "collectionStartedAt",
    "collectionCompletedAt",
    "device",
    "operatingSystem",
    "security",
    "collectionSummary"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^2\\.[0-9]+$" },
    "collectorVersion": { "type": "string" },
    "collectionMode": {
      "enum": ["STANDARD_USER_COLLECTION", "ELEVATED_COLLECTION"]
    },
    "collectionProfile": { "type": "string" },
    "privilegeContext": {
      "type": "object",
      "properties": {
        "executionMode": {
          "enum": [
            "STANDARD_USER",
            "ADMIN_MEMBER_NOT_ELEVATED",
            "ELEVATED_ADMINISTRATOR",
            "SYSTEM",
            "UNKNOWN"
          ]
        },
        "isElevated": { "type": "boolean" },
        "isLocalAdministratorMember": { "type": "boolean" },
        "integrityLevel": { "type": "string" },
        "effectiveUserHash": { "type": "string" }
      }
    },
    "capabilityResults": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capabilityId", "status"],
        "properties": {
          "capabilityId": { "type": "string" },
          "status": {
            "enum": [
              "COLLECTED",
              "COLLECTED_PARTIAL",
              "NOT_SUPPORTED",
              "NOT_COLLECTED_PRIVILEGE_REQUIRED",
              "NOT_COLLECTED_POLICY_BLOCKED",
              "NOT_COLLECTED_TIMEOUT",
              "NOT_COLLECTED_ACCESS_DENIED",
              "NOT_COLLECTED_ERROR"
            ]
          }
        }
      }
    },
    "collectionId": { "type": "string" },
    "collectionStartedAt": { "type": "string", "format": "date-time" },
    "collectionCompletedAt": { "type": "string", "format": "date-time" },
    "device": { "type": "object" },
    "operatingSystem": { "type": "object" },
    "security": {
      "type": "object",
      "properties": {
        "settings": {
          "type": "array",
          "items": { "$ref": "#/$defs/securitySetting" }
        }
      }
    },
    "updates": {
      "type": "object",
      "properties": {
        "settings": {
          "type": "array",
          "items": { "$ref": "#/$defs/securitySetting" }
        }
      }
    },
    "software": {
      "type": "object",
      "properties": {
        "items": {"type": "array", "items": {"type": "object"}}
      }
    },
    "services": {
      "type": "object",
      "properties": {
        "services": {"type": "array", "items": {"type": "object"}},
        "scheduledTasks": {"type": "array", "items": {"type": "object"}}
      }
    },
    "collectionSummary": {
      "type": "object",
      "properties": {
        "moduleInvocationCoveragePercent": {"type": "number", "minimum": 0, "maximum": 100},
        "successfulModulePercent": {"type": "number", "minimum": 0, "maximum": 100},
        "evidenceUnitCoveragePercent": {"type": "number", "minimum": 0, "maximum": 100},
        "mandatoryEvidenceCoveragePercent": {"type": "number", "minimum": 0, "maximum": 100},
        "moduleExecutionCoveragePercent": {"type": "number", "minimum": 0, "maximum": 100},
        "evidenceCollectionCoveragePercent": {"type": "number", "minimum": 0, "maximum": 100},
        "mandatoryCollectionCoveragePercent": {"type": "number", "minimum": 0, "maximum": 100},
        "mandatoryEvidenceApplicable": {"type": "integer", "minimum": 0},
        "mandatoryEvidenceCollected": {"type": "integer", "minimum": 0}
      }
    },
    "errors": { "type": "array" }
  },
  "$defs": {
    "securitySetting": {
      "type": "object",
      "required": [
        "settingId",
        "category",
        "collectionStatus",
        "confidence",
        "collectedAt",
        "provider"
      ],
      "properties": {
        "settingId": { "type": "string" },
        "category": { "type": "string" },
        "configuredValue": {},
        "effectiveValue": {},
        "source": {
          "enum": [
            "LOCAL_POLICY",
            "GROUP_POLICY",
            "MDM_POLICY",
            "REGISTRY",
            "DEFAULT",
            "RUNTIME_STATE",
            "SECURITY_PRODUCT",
            "UNKNOWN"
          ]
        },
        "collectionStatus": {
          "enum": [
            "SUCCESS",
            "PARTIAL",
            "FAILED",
            "NOT_SUPPORTED",
            "ACCESS_DENIED",
            "NOT_AVAILABLE"
          ]
        },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "collectedAt": { "type": "string", "format": "date-time" },
        "provider": { "type": "string" },
        "sourcePath": { "type": ["string", "null"] }
      }
    }
  }
}
