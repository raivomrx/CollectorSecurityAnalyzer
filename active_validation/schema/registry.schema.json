{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csa.local/schema/active-validator-registry-1.0.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "validators"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validatorId", "version", "module", "class", "status", "supportedRuleIds"],
        "properties": {
          "validatorId": {"type": "string", "pattern": "^VAL-[A-Z0-9-]+-[0-9]{3}$"},
          "version": {"type": "string"},
          "module": {"type": "string", "pattern": "^active_validation\\.validators\\."},
          "class": {"type": "string"},
          "status": {"enum": ["DRAFT", "REVIEW_REQUIRED", "ACTIVE", "DEPRECATED", "DISABLED"]},
          "supportedRuleIds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    }
  }
}
