{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csa.local/schema/active-validation-authorization-1.0.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "authorized", "assessmentId", "scope", "authorizedBy", "authorizedAt", "expiresAt", "purpose"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "authorized": {"const": true},
    "assessmentId": {"type": "string", "minLength": 1, "maxLength": 512},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deviceIdentifiers", "validatorIds"],
      "properties": {
        "deviceIdentifiers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "validatorIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        ,"networkInterfaces": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        ,"allowedSourceAddresses": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "ipv4"}}
        ,"allowedTargetAddresses": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "ipv4"}}
        ,"allowedProtocols": {"type": "array", "uniqueItems": true, "items": {"enum": ["LLMNR", "NBT_NS", "SMB", "HTTP"]}}
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nameResolutionSpoofing": {"type": "boolean"},
        "authenticationChallenge": {"type": "boolean"},
        "temporaryListener": {"type": "boolean"},
        "temporaryFirewallChange": {"type": "boolean"},
        "credentialMaterialRetention": {"const": false},
        "credentialRelay": {"const": false},
        "hashCracking": {"const": false},
        "explicitCurrentUserTest": {"type": "boolean"},
        "machineAccountObservation": {"type": "boolean"}
      }
    },
    "testIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "identifier", "credentialReference", "authorizedForAuthenticationTest"],
      "properties": {
        "mode": {"enum": ["DEDICATED_TEST_ACCOUNT", "SYNTHETIC_LOCAL_ACCOUNT", "EXPLICIT_CURRENT_USER_TEST", "MACHINE_ACCOUNT_OBSERVATION"]},
        "identifier": {"type": "string", "minLength": 1, "maxLength": 512},
        "credentialReference": {"type": "string", "pattern": "^(secure-runtime-reference|secret://[A-Za-z0-9._/-]+)$"},
        "authorizedForAuthenticationTest": {"const": true}
      }
    },
    "authorizedBy": {"type": "string", "minLength": 1, "maxLength": 512},
    "authorizedAt": {"type": "string", "format": "date-time"},
    "expiresAt": {"type": "string", "format": "date-time"},
    "purpose": {"type": "string", "minLength": 1, "maxLength": 512}
  }
}
