{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csa.local/schema/active-validation-authorization-1.0.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "authorized", "assessmentId", "scope", "authorizedBy", "authorizedAt", "expiresAt", "purpose"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "authorized": {"const": true},
    "assessmentId": {"type": "string", "minLength": 1, "maxLength": 512},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deviceIdentifiers", "validatorIds"],
      "properties": {
        "deviceIdentifiers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "validatorIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "authorizedBy": {"type": "string", "minLength": 1, "maxLength": 512},
    "authorizedAt": {"type": "string", "format": "date-time"},
    "expiresAt": {"type": "string", "format": "date-time"},
    "purpose": {"type": "string", "minLength": 1, "maxLength": 512}
  }
}
